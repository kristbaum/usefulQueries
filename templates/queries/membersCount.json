{
  "id": "membersCount",
  "scope": "property",
  "propertyId": [
    "P2124"
  ],
  "template": [
    "#defaultView:LineChart",
    "SELECT ?pit ?s_count WHERE {",
    "  wd:{itemQid} p:P2124 ?statement.",
    "  ?statement ps:P2124 ?s_count.",
    "  OPTIONAL { ?statement pq:P585 ?pit. }",
    "}"
  ],
  "emoji": "📊",
  "title": "Members count of {itemLabel} over time"
}